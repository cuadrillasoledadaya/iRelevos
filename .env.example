# Environment Variables for Relevos App

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key  # Server-side only, never expose to client

# Session Timeout: Configured in Supabase Dashboard → Auth → Settings → JWT Settings
# Set to 86400 seconds (24h inactivity). See docs/operations/security.md for details.

# iCuadrilla API Configuration
ICUADRILLA_API_TOKEN=your_icuadrilla_api_token
ICUADRILLA_API_URL=your_icuadrilla_api_url